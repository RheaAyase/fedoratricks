#!/bin/bash

set -Eeuo pipefail

cleanup() {
    nvidiadriversCleanup
}

nvidiadriversHelp() {
    cat << EOF
Command Usage: fedoratricks nvidiadrivers [options]

Note: This command installs proprietary NVIDIA drivers and configures kernel parameters.
It requires root privileges. OSTree-based systems (Silverblue/Kinoite) are not supported.

Options:
  -h|--help        Print the help text and exit.
  -i|--install     Install NVIDIA drivers and enable persistenced service.
  -r|--remove      Remove NVIDIA drivers and fall back to Nouveau.
  --sleep <arg>    Configure S0ix and memory preserve (enable | disable).
  --rebar <arg>    Configure Resizable BAR (enable | disable).
  --earlykms <arg> Configure Early KMS / MUX loading (enable | disable).
  --current        Override detection: Use current branch (Turing/RTX/Newer).
  --legacy-580xx   Override detection: Use 580xx branch (Maxwell/Pascal).
  --legacy-470xx   Override detection: Use 470xx branch (Kepler).

Examples:
  fedoratricks nvidiadrivers -i --sleep enable --earlykms enable
  fedoratricks nvidiadrivers --earlykms disable
  fedoratricks nvidiadrivers -r
EOF
}

# Always define option defaults:
action=""
nvidia_gen=""
sleep_state=""
rebar_state=""
earlykms_state=""
conf_file="/etc/modprobe.d/nvidia-fedoratricks.conf"
dracut_conf_file="/etc/dracut.conf.d/99-nvidia-fedoratricks.conf"

check_rpmfusion() {
    printf "Verifying RPM Fusion repositories...\n"
    local active_repos

    if ! active_repos=$(dnf repolist --enabled 2> /dev/null); then
        printf "Error: Failed to fetch dnf repolist.\n" >&2
        exit 1
    fi

    if ! grep -qi "rpmfusion-nonfree" <<< "${active_repos}"; then
        printf "\nError: RPM Fusion Non-Free repository is required but not enabled.\n" >&2
        printf "Please install and enable it first by running:\n\n" >&2
        printf "  sudo fedoratricks rpmfusion -i\n\n" >&2
        exit 1
    fi
}

detect_nvidia_gen() {
    printf "Detecting NVIDIA GPU generation...\n"

    local gpu_info=""
    if ! gpu_info=$(lspci | grep -i 'vga\|3d' | grep -i nvidia 2> /dev/null); then
        printf "Warning: Failed to read PCI devices or no NVIDIA GPU found.\n" >&2
        nvidia_gen="unknown"
        return
    fi

    printf "  Found GPU: %s\n" "${gpu_info}"

    # Turing, Ampere, Ada, Blackwell and newer (RTX 20+, GTX 16xx)
    if grep -qiE 'RTX|GTX 16[0-9][0-9]|MX[2345][0-9][0-9]|T[0-9][0-9][0-9]|A[0-9][0-9][0-9][0-9]' <<< "${gpu_info}"; then
        nvidia_gen="current"
    # Maxwell & Pascal (GTX 800/900/10xx)
    elif grep -qiE 'GTX 10[0-9][0-9]|GTX 9[0-9][0-9]|GTX 8[0-9][0-9]|MX1[0-9][0-9]|Quadro P|Quadro M|Pascal|Maxwell' <<< "${gpu_info}"; then
        nvidia_gen="580xx"
    # Kepler (GTX 600/700)
    elif grep -qiE 'GTX 7[0-9][0-9]|GTX 6[0-9][0-9]|Quadro K|Kepler' <<< "${gpu_info}"; then
        nvidia_gen="470xx"
    else
        nvidia_gen="unknown"
    fi

    if [[ ${nvidia_gen} == "unknown" ]]; then
        printf "Error: Could not automatically determine NVIDIA GPU generation family.\n" >&2
        printf "Please specify manually using --current, --legacy-580xx, or --legacy-470xx.\n" >&2
        exit 1
    fi

    printf "  Detected family: %s\n" "${nvidia_gen}"
}

regenerate_initramfs() {
    printf "Rebuilding initramfs image...\n"
    if command -v dracut > /dev/null 2>&1; then
        dracut --force || printf "Warning: dracut encountered an error.\n" >&2
    elif [[ -x "/usr/bin/dracut" ]]; then
        /usr/bin/dracut --force || printf "Warning: dracut encountered an error.\n" >&2
    elif [[ -x "/usr/sbin/dracut" ]]; then
        /usr/sbin/dracut --force || printf "Warning: dracut encountered an error.\n" >&2
    else
        printf "Warning: 'dracut' command not found. Initramfs not updated.\n" >&2
    fi
}

apply_nvidia_config() {
    local needs_initramfs=false

    if [[ ${sleep_state} == "enable" ]]; then
        printf "\nEnabling NVIDIA sleep optimizations (S0ix & Memory Preservation)...\n"
        touch "${conf_file}"
        sed -i '/NVreg_EnableS0ixPowerManagement/d' "${conf_file}"
        sed -i '/NVreg_PreserveVideoMemoryAllocations/d' "${conf_file}"

        printf "options nvidia NVreg_EnableS0ixPowerManagement=1\n" >> "${conf_file}"
        printf "options nvidia NVreg_PreserveVideoMemoryAllocations=1\n" >> "${conf_file}"

        systemctl enable nvidia-suspend.service nvidia-hibernate.service nvidia-resume.service || true
        needs_initramfs=true

    elif [[ ${sleep_state} == "disable" ]]; then
        printf "\nDisabling NVIDIA sleep optimizations...\n"
        if [[ -f ${conf_file} ]]; then
            sed -i '/NVreg_EnableS0ixPowerManagement/d' "${conf_file}"
            sed -i '/NVreg_PreserveVideoMemoryAllocations/d' "${conf_file}"
        fi
        systemctl disable nvidia-suspend.service nvidia-hibernate.service nvidia-resume.service || true
        needs_initramfs=true
    fi

    if [[ ${rebar_state} == "enable" ]]; then
        printf "\nEnabling NVIDIA Resizable BAR...\n"
        touch "${conf_file}"
        sed -i '/NVreg_EnableResizableBar/d' "${conf_file}"
        printf "options nvidia NVreg_EnableResizableBar=1\n" >> "${conf_file}"
        needs_initramfs=true

    elif [[ ${rebar_state} == "disable" ]]; then
        printf "\nDisabling NVIDIA Resizable BAR...\n"
        if [[ -f ${conf_file} ]]; then
            sed -i '/NVreg_EnableResizableBar/d' "${conf_file}"
        fi
        needs_initramfs=true
    fi

    if [[ ${earlykms_state} == "enable" ]]; then
        printf "\nEnabling NVIDIA Early KMS...\n"
        mkdir -p /etc/dracut.conf.d
        printf 'force_drivers+=" nvidia nvidia_modeset nvidia_uvm nvidia_drm "\n' > "${dracut_conf_file}"
        needs_initramfs=true

    elif [[ ${earlykms_state} == "disable" ]]; then
        printf "\nDisabling NVIDIA Early KMS...\n"
        if [[ -f ${dracut_conf_file} ]]; then
            rm -f "${dracut_conf_file}"
            needs_initramfs=true
        fi
    fi

    # Cleanup empty modprobe config file if everything was removed
    if [[ -f ${conf_file} && ! -s ${conf_file} ]]; then
        rm -f "${conf_file}"
    fi

    if [[ ${needs_initramfs} == true ]]; then
        regenerate_initramfs
    fi
}

nvidiadriversExecute() {
    printf "Executing <nvidiadrivers>\n"

    if [[ ! -f "/etc/fedora-release" ]]; then
        printf "Error: This command is intended for Fedora Linux only.\n" >&2
        exit 1
    fi

    if [[ -d "/run/ostree-booted" ]]; then
        printf "Error: OSTree-based systems are not supported for this NVIDIA command.\n" >&2
        exit 1
    fi

    if ! command -v dnf > /dev/null 2>&1; then
        printf "Error: 'dnf' package manager not found.\n" >&2
        exit 1
    fi

    if [[ ${EUID} -ne 0 ]]; then
        printf "Error: Please run this command as root (e.g., sudo fedoratricks nvidiadrivers -i).\n" >&2
        exit 1
    fi

    if [[ $# -eq 0 ]]; then
        nvidiadriversHelp
        exit 1
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h | --help)
                nvidiadriversHelp
                exit 0
                ;;
            -i | --install)
                if [[ ${action} == "remove" ]]; then
                    printf "Error: Conflicting actions specified ('remove' and 'install').\n" >&2
                    exit 1
                fi
                action="install"
                shift
                ;;
            -r | --remove)
                if [[ ${action} == "install" ]]; then
                    printf "Error: Conflicting actions specified ('install' and 'remove').\n" >&2
                    exit 1
                fi
                action="remove"
                shift
                ;;
            --sleep)
                if [[ $2 != "enable" && $2 != "disable" ]]; then
                    printf "Error: --sleep requires 'enable' or 'disable'.\n" >&2
                    exit 1
                fi
                sleep_state="$2"
                if [[ -z ${action} ]]; then action="config"; fi
                shift 2
                ;;
            --rebar)
                if [[ $2 != "enable" && $2 != "disable" ]]; then
                    printf "Error: --rebar requires 'enable' or 'disable'.\n" >&2
                    exit 1
                fi
                rebar_state="$2"
                if [[ -z ${action} ]]; then action="config"; fi
                shift 2
                ;;
            --earlykms)
                if [[ $2 != "enable" && $2 != "disable" ]]; then
                    printf "Error: --earlykms requires 'enable' or 'disable'.\n" >&2
                    exit 1
                fi
                earlykms_state="$2"
                if [[ -z ${action} ]]; then action="config"; fi
                shift 2
                ;;
            --current)
                nvidia_gen="current"
                shift
                ;;
            --legacy-580xx)
                nvidia_gen="580xx"
                shift
                ;;
            --legacy-470xx)
                nvidia_gen="470xx"
                shift
                ;;
            *)
                if [[ $1 == -* ]]; then
                    printf "Unknown option: %s\n" "$1" >&2
                    exit 1
                else
                    printf "Unknown argument: '%s'. See --help for options.\n" "$1" >&2
                    exit 1
                fi
                ;;
        esac
    done

    if [[ -z ${action} ]]; then
        printf "Error: No action specified. Use -i|--install, -r|--remove, or configure flags (--sleep, --rebar, --earlykms).\n" >&2
        exit 1
    fi

    # DO STUFF
    if [[ ${action} == "remove" ]]; then
        printf "\nRemoving proprietary NVIDIA drivers and utilities...\n"

        dnf remove -y "akmod-nvidia*" "xorg-x11-drv-nvidia*" || true

        printf "Disabling nvidia-persistenced service...\n"
        systemctl disable --now nvidia-persistenced.service || true

        # Wipe custom configurations
        if [[ -f ${conf_file} || -f ${dracut_conf_file} ]]; then
            rm -f "${conf_file}" "${dracut_conf_file}"
            regenerate_initramfs
        fi

        printf "\nNVIDIA drivers uninstalled successfully.\n"
        printf "Please REBOOT to fall back to the open-source Nouveau drivers.\n"

    elif [[ ${action} == "install" ]]; then
        check_rpmfusion

        if [[ -z ${nvidia_gen} ]]; then
            detect_nvidia_gen
        fi

        printf "\nInstalling NVIDIA drivers (Branch: %s)...\n" "${nvidia_gen}"

        local target_akmod=""
        local target_cuda=""

        if [[ ${nvidia_gen} == "current" ]]; then
            target_akmod="akmod-nvidia"
            target_cuda="xorg-x11-drv-nvidia-cuda"
        elif [[ ${nvidia_gen} == "580xx" ]]; then
            target_akmod="akmod-nvidia-580xx"
            target_cuda="xorg-x11-drv-nvidia-580xx-cuda"
        elif [[ ${nvidia_gen} == "470xx" ]]; then
            target_akmod="akmod-nvidia-470xx"
            target_cuda="xorg-x11-drv-nvidia-470xx-cuda"
        fi

        dnf install -y "${target_akmod}" "${target_cuda}"

        printf "Enabling nvidia-persistenced service...\n"
        systemctl enable --now nvidia-persistenced.service || printf "Warning: Could not enable nvidia-persistenced.\n" >&2

        # Apply optional configurations if specified during install
        if [[ -n ${sleep_state} || -n ${rebar_state} || -n ${earlykms_state} ]]; then
            apply_nvidia_config
        fi

        printf "\n============================================================\n"
        printf " NVIDIA driver installation staged successfully.\n"
        printf " IMPORTANT: Please wait 3 to 5 minutes before rebooting to\n"
        printf " allow the AKMOD system to compile the kernel module locally.\n"
        printf "============================================================\n"

    elif [[ ${action} == "config" ]]; then
        apply_nvidia_config
        printf "\nNVIDIA configuration updated successfully.\n"
    fi
}

nvidiadriversCleanup() {
    printf "Cleaned up after <nvidiadrivers>\n"
    exit 2
}
